# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Shell scripts must stay LF (even on Windows)
*.sh text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.svg -text
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.gz binary
*.exe binary
*.dll binary
*.dylib binary
*.so binary
*.node binary
